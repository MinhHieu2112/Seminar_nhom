generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int           @id @default(autoincrement())
  name          String
  email         String           @unique
  phone         String?
  passwordHash  String?
  role          Role             @default(customer)
  avatar        String?
  createdAt     DateTime         @default(now())
  addresses     Address[]
  notifications Notification[]
  orders        Order[]
  reviews       Review[]
  serviceReqs   ServiceRequest[]

  @@map("users")
}

model Address {
  id        Int                  @id @default(autoincrement())
  userId    Int
  name      String
  phone     String
  address   String
  isDefault Boolean @default(false)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "addresses_userId_fkey")
  @@map("addresses")
}

model Category {
  id       Int     @id @default(autoincrement())
  name     String     @unique
  parentId Int?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]

  @@index([parentId], map: "categories_parentId_fkey")
  @@map("categories")
}

model Product {
  id          Int         @id @default(autoincrement())
  name        String
  sku         String         @unique
  price       Float
  discount    Int            @default(0)
  stock       Int            @default(0)
  material    String
  dimension   String
  weight      Float
  description String @db.Text
  status      ProductStatus  @default(active)
  rating      Float          @default(0)
  createdAt   DateTime       @default(now())
  categoryId  Int
  orderItems  OrderItem[]
  images      ProductImage[]
  category    Category       @relation(fields: [categoryId], references: [id])
  reviews     Review[]

  @@index([categoryId])
  @@map("products")
}

model ProductImage {
  id        Int  @id @default(autoincrement())
  productId Int
  imageUrl  String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId], map: "product_images_productId_fkey")
  @@map("product_images")
}

model Review {
  id        Int   @id @default(autoincrement())
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  productId Int
  userId    Int
  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([userId], map: "reviews_userId_fkey")
  @@map("reviews")
}

model Order {
  id              BigInt      @id @default(autoincrement())
  totalAmount     Float
  discountApplied Float?
  status          OrderStatus @default(pending)
  shippingAddress String
  createdAt       DateTime    @default(now())
  userId          Int
  items           OrderItem[]
  user            User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("orders")
}

model OrderItem {
  id        BigInt  @id @default(autoincrement())
  quantity  Int
  price     Float
  orderId   BigInt
  productId Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@index([orderId], map: "order_items_orderId_fkey")
  @@index([productId], map: "order_items_productId_fkey")
  @@map("order_items")
}

model DiscountCode {
  code      String    @id
  value     Float
  type      DiscountType
  expiredAt DateTime?

  @@map("discount_codes")
}

model Service {
  id          Int           @id @default(autoincrement())
  name        String
  basePrice   Float
  description String @db.Text
  requests    ServiceRequest[]

  @@map("services")
}

model ServiceRequest {
  id        Int               @id @default(autoincrement())
  area      Float
  budget    Float
  note      String
  status    ServiceRequestStatus @default(new)
  createdAt DateTime             @default(now())
  userId    Int
  serviceId Int
  service   Service              @relation(fields: [serviceId], references: [id])
  user      User                 @relation(fields: [userId], references: [id])

  @@index([serviceId], map: "service_requests_serviceId_fkey")
  @@index([userId], map: "service_requests_userId_fkey")
  @@map("service_requests")
}

model Project {
  id            Int        @id @default(autoincrement())
  name          String
  location      String
  area          Float
  style         String
  completedYear Int
  description String @db.Text
  images        ProjectImage[]

  @@map("projects")
}

model ProjectImage {
  id        Int  @id @default(autoincrement())
  projectId Int
  imageUrl  String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId], map: "project_images_projectId_fkey")
  @@map("project_images")
}

model Notification {
  id        Int           @id @default(autoincrement())
  title     String
  content   String
  type      NotificationType
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  userId    Int
  user      User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("notifications")
}

enum Role {
  customer
  staff
  admin
}

enum OrderStatus {
  pending
  paid
  shipping
  completed
  cancelled
}

enum ProductStatus {
  active
  inactive
}

enum DiscountType {
  percent
  fixed
}

enum NotificationType {
  order
  promo
  system
}

enum ServiceRequestStatus {
  new
  consulting
  quoted
  contracted
  done
}
