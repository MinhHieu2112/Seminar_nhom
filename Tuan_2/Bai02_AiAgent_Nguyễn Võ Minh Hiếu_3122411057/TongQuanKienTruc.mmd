graph TD
    subgraph "User Interface"
        Telegram[Telegram Bot UI]
    end

    subgraph "n8n Orchestration Layer (Docker)"
        Trigger[Telegram Trigger]
        Switch{Router / Switch Node}
        LLM_Chain[Basic LLM Chain]
        HTTP_Node[HTTP Request: TMDB]
        Code_Node[Get Movie in Week]
    end

    subgraph "External Resources"
        TMDB_API[(TheMovieDB API)]
        Gemini_API[(Gemini AI Service)]
    end

    Telegram <--> Trigger
    Trigger --> Switch
    
    %% Luồng AI
    Switch -- "Case: General Chat" --> LLM_Chain
    LLM_Chain <--> Gemini_API
    
    %% Luồng Data
    Switch -- "Case: /phim" --> HTTP_Node
    HTTP_Node <--> TMDB_API
    HTTP_Node --> Code_Node
    Code_Node --> Telegram