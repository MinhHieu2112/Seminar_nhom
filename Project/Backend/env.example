# Backend Environment Variables
# Copy this file to .env

NODE_ENV=development

# API Gateway (HTTP)
GATEWAY_PORT=8000
FRONTEND_URL=http://localhost:3000

# JWT Secrets (change in production!)
JWT_SECRET=dev_jwt_secret_change_in_production
REFRESH_TOKEN_SECRET=dev_refresh_secret_change_in_production

# Microservices (TCP)
USER_SERVICE_HOST=localhost
USER_SERVICE_PORT=8001
SCHEDULER_SERVICE_HOST=localhost
SCHEDULER_SERVICE_PORT=8003
NOTIFICATION_SERVICE_HOST=localhost
NOTIFICATION_SERVICE_PORT=8002
AI_SERVICE_HOST=localhost
AI_SERVICE_PORT=8005

# Calendar Service (TCP)
# FIX: port phải match với tcp-client.service.ts default (8004)
CALENDAR_SERVICE_HOST=localhost
CALENDAR_SERVICE_PORT=8004

# Database (PostgreSQL)
DATABASE_URL=postgresql://studyplan:secret@localhost:5432/studyplan

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Pomodoro Settings
POMODORO_WORK_MIN=25
POMODORO_SHORT_BREAK_MIN=5
POMODORO_LONG_BREAK_MIN=15
POMODORO_LONG_BREAK_AFTER=4

# Email SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@studyplan.app
