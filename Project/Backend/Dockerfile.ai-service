# Multi-stage build for AI Service (TCP Microservice)
FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

# Production stage
FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
RUN npm ci --only=production && npm cache clean --force

COPY --from=builder /app/dist ./dist

EXPOSE 8005

# Entry point: main.ai.js (compiled from src/main.ai.ts)
CMD ["node", "dist/main.ai.js"]
