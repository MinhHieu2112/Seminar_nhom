@page "/items"
@inject System.Net.Http.HttpClient Http

<h2>Items</h2>

<div>
  <label>Name: <input @bind="name" /></label>
  <label>Description: <input @bind="description" /></label>
  <label>Price: <input type="number" step="0.01" @bind="price" /></label>
  <button @onclick="CreateItem">Create</button>
</div>

<div>
  @if (items == null)
  {
    <p>Loading...</p>
  }
  else
  {
    @foreach (var it in items)
    {
      <div class="item">
        <strong>@it.name</strong>
        <div>@it.description</div>
        <div>Price: @it.price</div>
      </div>
    }
  }
</div>

@code {
    private string name = string.Empty;
    private string description = string.Empty;
    private double? price;

    private List<ItemDto>? items;

    protected override async Task OnInitializedAsync()
    {
        items = await Http.GetFromJsonAsync<List<ItemDto>>("/items");
    }

    private async Task CreateItem()
    {
        var payload = new { name = name, description = description, price = price };
        var resp = await Http.PostAsJsonAsync("/items", payload);
        if (resp.IsSuccessStatusCode)
        {
            items = await Http.GetFromJsonAsync<List<ItemDto>>("/items");
            name = description = string.Empty;
            price = null;
        }
    }

    private record ItemDto(int id, string name, string? description, double? price, DateTime createdAt);
}
